{
  "name": "typescript-template",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "audit": "pnpm audit",
    "audit:osv": "osv-scanner scan -r .",
    "audit:supply-chain": "pnpm audit",
    "build": "pnpm build:common && pnpm build:agents && pnpm build:backend && pnpm build:frontend",
    "build:agents": "pnpm --filter \"@llmops-demo-ts/agents\" build",
    "build:backend": "pnpm --filter \"@llmops-demo-ts/backend\" build",
    "build:common": "pnpm --filter \"@llmops-demo/common\" build",
    "build:frontend": "pnpm --filter \"@llmops-demo-ts/frontend\" build",
    "fix-audit": "pnpm audit --fix",
    "format": "trunk fmt",
    "install:playwright": "pnpm --filter @llmops-demo-ts/frontend exec playwright install",
    "lint": "trunk check .",
    "lint:eslint": "eslint --config eslint.config.js --fix",
    "playwright:report": "pnpm --filter @llmops-demo-ts/frontend exec playwright show-report",
    "start:backend": ". .env && pnpm --filter @llmops-demo-ts/backend dev",
    "start:frontend": "pnpm --filter @llmops-demo-ts/frontend dev",
    "test": "pnpm test:common && pnpm test:agents && pnpm test:backend && pnpm test:frontend",
    "test:agents": "pnpm --filter @llmops-demo-ts/agents test",
    "test:backend": "pnpm --filter @llmops-demo-ts/backend test",
    "test:common": "pnpm --filter @llmops-demo/common test",
    "test:frontend": "pnpm --filter @llmops-demo-ts/frontend test:e2e",
    "upgrade": "pnpm up --recursive --latest"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^4.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "typescript": "^6.0.2",
    "vue-eslint-parser": "^10.4.0"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@1.1.12": "1.1.13",
      "brace-expansion@2.0.2": "2.0.3",
      "brace-expansion@5.0.4": "5.0.5",
      "flatted": "3.4.2",
      "handlebars": "4.7.9",
      "minimatch@10.2.1": "10.2.5",
      "path-to-regexp@0.1.12": "0.1.13",
      "path-to-regexp@8.3.0": "8.4.2",
      "picomatch@2.3.1": "2.3.2",
      "picomatch@4.0.3": "4.0.4",
      "yaml": "2.8.3"
    }
  }
}
